{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/gamehub",
      "destination": "/gamehub/index.html"
    },
    {
      "source": "/gamehub/:path*",
      "destination": "/gamehub/:path*.html"
    },
    {
      "source": "/gamehub/:path*",
      "destination": "/gamehub/:path*"
    }
  ]
}