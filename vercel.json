{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/gamehub",
      "destination": "/gamehub/index.html"
    },
    {
      "source": "/gamehub/:match",
      "destination": "/gamehub/:match.html"
    },
    {
      "source": "/gamehub/:match*",
      "destination": "/gamehub/:match*"
    }
  ]
}